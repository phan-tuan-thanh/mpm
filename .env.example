# =============================================================================
# Agile PM — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=mpm
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=mpm
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Database URL for NestJS/TypeORM connection
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=changeme_redis_password
REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# -----------------------------------------------------------------------------
# Authentik (Identity Provider)
# -----------------------------------------------------------------------------
AUTHENTIK_SECRET_KEY=changeme_authentik_secret_key_min_50_chars_long_random_string
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_PORT=9000
AUTHENTIK_PORT_HTTPS=9443

# Authentik OAuth2/OIDC client credentials (configured in Authentik admin)
AUTHENTIK_CLIENT_ID=your_oauth2_client_id
AUTHENTIK_CLIENT_SECRET=your_oauth2_client_secret
AUTHENTIK_ISSUER_URL=http://localhost:9000/application/o/agile-pm/
AUTHENTIK_AUTHORIZE_URL=http://localhost:9000/application/o/authorize/
AUTHENTIK_TOKEN_URL=http://localhost:9000/application/o/token/
AUTHENTIK_USERINFO_URL=http://localhost:9000/application/o/userinfo/
AUTHENTIK_END_SESSION_URL=http://localhost:9000/application/o/agile-pm/end-session/
AUTHENTIK_JWKS_URL=http://localhost:9000/application/o/agile-pm/jwks/
AUTHENTIK_REDIRECT_URI=http://localhost:4200/auth/callback

# -----------------------------------------------------------------------------
# JWT (RS256 Asymmetric Keys)
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
BACKEND_PORT=3000
FRONTEND_URL=http://localhost:4200

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_REFRESH_MAX=10
RATE_LIMIT_REFRESH_WINDOW_SECONDS=60
