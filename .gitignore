# =============================================================================
# Agile PM — .gitignore
# =============================================================================

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
build/
.angular/
tmp/
out-tsc/

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
keys/
*.pem

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Test & Coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/
junit.xml

# ─── Docker ───────────────────────────────────────────────────────────────────
# Volumes data (managed by Docker, not committed)
docker/postgres_data/
docker/redis_data/

# ─── TypeORM ──────────────────────────────────────────────────────────────────
# Migration output (keep .ts source, ignore compiled)
migrations/*.js
migrations/*.js.map

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.tsbuildinfo
.eslintcache
.cache/
